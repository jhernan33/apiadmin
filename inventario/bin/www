#!/usr/bin/env node

'use strict';

const app = require('../app');
const http = require('http');
const { sequelize } = require('../models');

/**
 * Normaliza el puerto a número, string (named pipe) o false.
 * @param {string} val
 * @returns {number|string|boolean}
 */
function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) return val;   // named pipe
  if (port >= 0) return port;    // número de puerto
  return false;
}

const port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

const server = http.createServer(app);

// ── Manejo de errores del servidor ───────────────────────
server.on('error', (error) => {
  if (error.syscall !== 'listen') throw error;

  const bind = typeof port === 'string' ? `Pipe ${port}` : `Port ${port}`;

  switch (error.code) {
    case 'EACCES':
      console.error(`[Server] ${bind} requiere privilegios de administrador`);
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(`[Server] ${bind} ya está en uso`);
      process.exit(1);
      break;
    default:
      throw error;
  }
});

server.on('listening', () => {
  const addr = server.address();
  const bind = typeof addr === 'string' ? `pipe ${addr}` : `port ${addr.port}`;
  console.log(`[Server] Escuchando en ${bind} (${process.env.NODE_ENV || 'development'})`);
});

// ── Graceful Shutdown ────────────────────────────────────
// Garantiza que las conexiones activas terminen limpiamente
// antes de apagar el proceso (crítico en Docker/Kubernetes).

const shutdown = async (signal) => {
  console.log(`[Server] ${signal} recibida. Cerrando gracefully...`);

  server.close(async () => {
    try {
      await sequelize.close();
      console.log('[Server] Conexión a BD cerrada correctamente.');
      process.exit(0);
    } catch (err) {
      console.error('[Server] Error al cerrar la BD:', err.message);
      process.exit(1);
    }
  });

  // Forzar cierre si no termina en 10 segundos
  setTimeout(() => {
    console.error('[Server] Timeout en shutdown. Forzando cierre.');
    process.exit(1);
  }, 10_000).unref(); // .unref() evita que este timer bloquee el event loop
};

process.on('SIGTERM', () => shutdown('SIGTERM')); // Docker / Kubernetes
process.on('SIGINT', () => shutdown('SIGINT'));   // Ctrl+C en desarrollo

// ── Iniciar servidor ─────────────────────────────────────
server.listen(port);
