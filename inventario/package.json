{
  "name": "inventario",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "dev": "NODE_ENV=development nodemon ./bin/www",
    "test": "NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:unit": "NODE_ENV=test jest tests/unit --forceExit",
    "test:integration": "NODE_ENV=test jest tests/integration --forceExit",
    "test:coverage": "NODE_ENV=test jest --coverage --forceExit",
    "test:watch": "NODE_ENV=test jest --watch",
    "lint": "eslint .",
    "audit": "npm audit",
    "update:safe": "bash scripts/update-deps.sh --safe",
    "update:major": "bash scripts/update-deps.sh --major",
    "update:full": "bash scripts/update-deps.sh --full"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/scripts/"
    ],
    "modulePathIgnorePatterns": [
      "/scripts/.backups/"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "/migrations/",
      "/scripts/"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "body-parser": "1.20.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "16.4.7",
    "ejs": "3.1.10",
    "express": "4.22.1",
    "express-rate-limit": "7.5.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "pg-hstore": "2.3.4",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
