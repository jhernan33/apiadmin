# ─── Servidor ────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de Datos ────────────────────────────────────────
# Sequelize CLI usa DATABASE_URL si está definida.
# Si no, se construye automáticamente desde las variables DB_*
DATABASE_URL=postgres://user:password@localhost:5432/inventario_db

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_secure_password
DB_NAME=inventario_db
DB_DIALECT=postgres
DB_SSL=false

# ─── Seguridad ────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_chars_random_string
JWT_EXPIRES_IN=24h
SESSION_SECRET=CHANGE_ME_min_32_chars_random_string

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
